# Optional: Default MCP server URL
NEXT_PUBLIC_DEFAULT_SERVER_URL=https://your-server.com/mcp

# Password reset emails via Resend (https://resend.com)
# Without these, reset URLs are logged to the server console instead.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HTTPS Configuration
# For development with HTTPS, set to true
HTTPS_ENABLED=false
HTTPS_PORT=3443

# Production HTTPS (auto-detected in most cases)
NODE_ENV=development
